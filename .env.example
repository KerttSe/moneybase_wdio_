MB_COUNTRY=Malta
MB_PHONE=99011190
MB_PIN=2468

# OTP API (Android beneficiary flow)
# Option A: full URL template, e.g. https://host.moneybase.com/otp/otp/getLatest/{phone}
OTP_GET_LATEST_URL=https://stgadminapi.moneybase.com/otp/otp/getLatest/{phone}
# Option B: base URL only, helper builds /otp/otp/getLatest/{phone}
OTP_API_BASE_URL=
# Optional phone override.
# For stgadmin OTP endpoint use international format with spaces, e.g. +356 9901 1190
OTP_PHONE=+356 9901 1190
# Optional country code used for phone normalization
OTP_COUNTRY_CODE=356
OTP_TIMEOUT_MS=90000
OTP_FETCH_DELAY_MS=0
OTP_KEY_INTERVAL_MS=250
OTP_STEP_TIMEOUT_MS=45000
OTP_WAIT_INTERVAL_MS=1000
# Beneficiary OTP can auto-accept after typing; these waits cover that backend transition.
BENEFICIARY_OTP_ACCEPT_TIMEOUT_MS=30000
BENEFICIARY_OTP_TRANSITION_TIMEOUT_MS=90000
# Optional: force tap on "Resend Code" before OTP fetch
OTP_FORCE_RESEND_BEFORE_FETCH=true
OTP_RESEND_WAIT_MS=70000
OTP_POST_RESEND_PAUSE_MS=1500

# Wait profile.
# Keep tap/input short; increase transition/backend waits for slow BrowserStack/STG runs.
WDIO_WAIT_PROBE_MS=1000
WDIO_WAIT_TAP_MS=10000
WDIO_WAIT_INPUT_MS=12000
WDIO_WAIT_ELEMENT_MS=15000
WDIO_WAIT_TRANSITION_MS=45000
WDIO_WAIT_BACKEND_MS=90000
WDIO_WAIT_HEAVY_BACKEND_MS=120000
WDIO_WAIT_INTERVAL_MS=500
SPEC_MOCHA_TIMEOUT_MS=600000

# Optional auth/headers for OTP admin endpoint
# OTP_API_AUTH_TOKEN=Bearer <token>
# OTP_API_COOKIE=<cookie>
# OTP_API_HEADERS_JSON={"x-api-key":"<key>"}

# BrowserStack
BROWSERSTACK=true
PLATFORM=
APPIUM_PORT=4723
IOS_UDID=
IOS_DEVICE_NAME=iPhone
IOS_APP=/Users/dmytrokertys/Desktop/app/moneybase.app
ANDROID_UDID=
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BS_APP_ANDROID=
BS_APP_IOS=
BS_PROJECT=moneybase_wdio
BS_BUILD=
BS_ANDROID_DEVICE=Google Pixel 6
BS_ANDROID_OS=14.0
BS_ANDROID_APP_PACKAGE=
BS_ANDROID_APP_ACTIVITY=
BS_IOS_DEVICE=iPhone 14
BS_IOS_OS=16
BS_IOS_BUNDLE_ID=
# BrowserStack debugging/reporting.
# deviceLogs = Android logcat / iOS device logs, networkLogs = HAR tab in BrowserStack.
BS_DEBUG=true
BS_APPIUM_LOGS=true
BS_DEVICE_LOGS=true
BS_NETWORK_LOGS=true
# Keep false by default because request/response bodies may contain sensitive data.
BS_NETWORK_LOGS_CAPTURE_CONTENT=false

# BrowserStack camera media injection for Onfido.
# Upload JPG/PNG document frames to BrowserStack media API,
# then paste returned media:// URLs here. The test injects front before first shutter tap
# and back before second shutter tap.
ONBOARDING_CAMERA_FRONT_MEDIA_URL=
ONBOARDING_CAMERA_BACK_MEDIA_URL=
ONBOARDING_CAMERA_FACE_MEDIA_URL=
# Optional MP4 document media. In BrowserStack video mode these are preferred over JPG/PNG.
ONBOARDING_CAMERA_FRONT_VIDEO_MEDIA_URL=
ONBOARDING_CAMERA_BACK_VIDEO_MEDIA_URL=
# Set to image to force document capture through cameraImageInjection while liveness uses video.
ONBOARDING_DOCUMENT_CAMERA_INJECTION=
# BrowserStack video camera injection for liveness flows.
# Upload MP4 via https://api-cloud.browserstack.com/app-automate/upload-media,
# then pass the returned media:// URL here.
ONBOARDING_CAMERA_LIVE_VIDEO_MEDIA_URL=
# Set video=true to run all Onfido camera steps through video injection only.
# When video injection is enabled, image injection is intentionally not enabled to avoid BS conflicts.
BS_ENABLE_CAMERA_IMAGE_INJECTION=
BS_ENABLE_CAMERA_VIDEO_INJECTION=
# Optional BrowserStack camera preview. Keep false unless your plan supports it.
BS_ENABLE_CAMERA_PREVIEW=false
